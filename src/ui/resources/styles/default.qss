}

[palette="light"] SettingsDialog QSlider::handle:horizontal {
    background: #4a90d9;
    border: 2px solid #ffffff;
}

[palette="light"] SettingsDialog QSlider::sub-page:horizontal {
    background: #4a90d9;
}

[palette="light"] SettingsDialog QSlider::add-page:horizontal {
    background: #e0e0e0;
}

[palette="light"] SettingsDialog QSpinBox {
    background: #ffffff;
    border-color: #d0d0d0;
    color: #333333;
}

[palette="light"] SettingsDialog QSpinBox:hover,
[palette="light"] SettingsDialog QSpinBox:focus {
    border-color: #4a90d9;
}

[palette="light"] SettingsDialog QListWidget {
    background: #ffffff;
    border-color: #d0d0d0;
    color: #333333;
}

[palette="light"] SettingsDialog QListWidget::item:selected {
    background: #4a90d9;
    color: #ffffff;
}

[palette="light"] SettingsDialog QListWidget::item:hover {
    background: #f5f5f5;
}

[palette="light"] SettingsDialog QPushButton {
    background: #ffffff;
    border-color: #d0d0d0;
    color: #333333;
}

[palette="light"] SettingsDialog QPushButton:hover {
    background: #f5f5f5;
    border-color: #4a90d9;
}

[palette="light"] SettingsDialog QPushButton:pressed {
    background: #e0e0e0;
}
